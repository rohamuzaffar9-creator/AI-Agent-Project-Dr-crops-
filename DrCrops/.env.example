# NVIDIA NIM API key — get from https://build.nvidia.com
NVIDIA_API_KEY=

# Google Maps JavaScript API key — get from https://console.cloud.google.com
# On VERCEL: set NEXT_PUBLIC_GOOGLE_MAPS_API_KEY in Project Settings →
#   Environment Variables, then redeploy. Also whitelist your *.vercel.app
#   domain in Google Cloud → Credentials → Application restrictions.
# Locally, either name works (next.config.mjs aliases VITE_ → NEXT_PUBLIC_).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# VITE_GOOGLE_MAPS_API_KEY=

# Sentinel Hub OAuth client (Process + Statistics API for NDVI)
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=
